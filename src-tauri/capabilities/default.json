{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "core:event:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "editor",
          "cmd": { "validator": "^[A-Za-z]:\\\\\\\\.+\\\\\\\\[^\\\\\\\\]+\\\\.exe$" },
          "args": [{ "validator": "^.+$" }],
          "sidecar": false
        }
      ]
    }
  ]
}
